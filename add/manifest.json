  "shortcuts": [
    {
      "name": "今すぐお題目する",
      "short_name": "お題目",
      "description": "アプリを開いてお題目カウントを開始",
      "url": "/?shortcut=chanting",
      "icons": [
        {
          "src": "/images/icon-shortcut-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "統計を見る",
      "short_name": "統計",
      "description": "ダッシュボードで勤行統計を表示",
      "url": "/?shortcut=stats",
      "icons": [
        {
          "src": "/images/icon-shortcut-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "リーダーボード",
      "short_name": "ランク",
      "description": "リーダーボードランクを確認",
      "url": "/?shortcut=leaderboard",
      "icons": [
        {
          "src": "/images/icon-shortcut-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+yomuyomu",
      "url": "/?action=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [
          ".json"
        ]
      },
      "launch_type": "single-client"
    }
  ]
}
